generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  role      String   @default("XML_OPERATOR") // ADMIN, EDITORIAL_MANAGER, XML_OPERATOR, REVIEWER
  status    String   @default("ACTIVE")
  lastLogin DateTime?
  articles  Article[]
  historyLogs ArticleHistory[]
  systemLogs  SystemLog[]
  resetTokens ResetToken[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Article {
  id               String   @id @default(cuid())
  title            String?
  originalFileName String
  fileUrl          String?
  status           String   @default("UPLOADED") // UPLOADED, METADATA_EXTRACTED, UNDER_REVIEW, XML_GENERATED, VALIDATION_FAILED, VALIDATION_PASSED, READY_FOR_EXPORT, SUBMITTED
  uploaderId       String
  uploader         User     @relation(fields: [uploaderId], references: [id])
  metadata         Metadata?
  references       Reference[]
  figures          Figure[]
  tables           ArticleTable[]
  authors          Author[]
  history          ArticleHistory[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Metadata {
  id               String   @id @default(cuid())
  articleId        String   @unique
  article          Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  title            String?
  runningTitle     String?
  subtitle         String?
  abstract         String?
  keywords         String?
  journalName      String?
  volume           String?
  issue            String?
  pages            String?
  doi              String?
  publicationDate  DateTime?
  fundingInfo      String?
  grantNumbers     String?
  conflictOfInterest String?
  ethicalApproval  String?
  acknowledgements String?
  bodyHtml         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Reference {
  id          String   @id @default(cuid())
  articleId   String
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  rawText     String
  authors     String?
  title       String?
  journal     String?
  year        String?
  doi         String?
  pmid        String?
  volume      String?
  issue       String?
  pages       String?
}

model Figure {
  id          String   @id @default(cuid())
  articleId   String
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  label       String?
  caption     String?
  base64Data  String?
}

model ArticleTable {
  id          String   @id @default(cuid())
  articleId   String
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  label       String?
  caption     String?
  htmlContent String?
}

model Author {
  id          String   @id @default(cuid())
  articleId   String
  article     Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  name        String
  affiliation String?
  email       String?
  orcid       String?
  isCorresponding Boolean @default(false)
  order       Int @default(0)
}

model ArticleHistory {
  id               String   @id @default(cuid())
  articleId        String
  article          Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId           String?
  user             User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  metadataSnapshot String   // Stored as JSON string
  createdAt        DateTime @default(now())
}

model SystemSettings {
  id                   String   @id @default("global")
  pmcFtpHost           String?
  pmcFtpUser           String?
  pmcFtpPassword       String?
  porticoFtpHost       String?
  porticoFtpUser       String?
  porticoFtpPassword   String?
  scieloApiToken       String?
  crossrefUsername     String?
  crossrefPassword     String?
  doajApiKey           String?
  googleScholarKey     String?
  openAireToken        String?
  scopusKey            String?
  wosKey               String?
  oaiEnabled           Boolean  @default(true)
  require2FA           Boolean  @default(false)
  logMetadataChanges   Boolean  @default(true)
  allowReviewerSource  Boolean  @default(false)
  convertXmlToHtml     Boolean  @default(true)
  sourceRetentionDays  Int      @default(30)
  zipRetentionDays     Int      @default(90)
  updatedAt            DateTime @updatedAt
}

model SystemLog {
  id        String   @id @default(cuid())
  action    String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  status    String   @default("SUCCESS") // SUCCESS, FAILED, WARNING
  details   String?
  createdAt DateTime @default(now())
}
